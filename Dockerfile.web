# Loop Engineering — Web image (multi-stage)
#
# Stage 1 (deps): npm install baked into a layer.
#   Rebuilt only when package.json changes.
#
# Stage 2 (runtime): copies baked node_modules from deps.
#   Source files are bind-mounted at runtime (no reinstall on startup).

# ── Stage 1: dependency installer ────────────────────────────────────────────
FROM node:22-slim AS deps
WORKDIR /app
COPY packages/web/package.json ./
RUN npm install --no-audit --no-fund

# ── Stage 2: runtime ─────────────────────────────────────────────────────────
FROM node:22-slim AS runtime
WORKDIR /app

# Bake in node_modules — NOT overwritten by source bind mounts
COPY --from=deps /app/node_modules ./node_modules

# Bake in package.json for npm scripts (dev / build / start)
COPY packages/web/package.json ./

# Source tree is mounted at runtime via docker-compose volumes:
#   ./packages/web/src        -> /app/src
#   ./packages/web/next.config.ts -> /app/next.config.ts
#   ./packages/web/tsconfig.json  -> /app/tsconfig.json
#   ./packages/web/tailwind.config.ts -> /app/tailwind.config.ts
#   ./packages/web/postcss.config.js  -> /app/postcss.config.js

EXPOSE 4000

# WATCHPACK_POLLING: ensures file-change detection works across bind mounts
ENV WATCHPACK_POLLING=true

CMD ["npm", "run", "dev"]
